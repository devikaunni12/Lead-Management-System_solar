# This file is an example of environment variables for this project.
# Copy this file to .env if you want to customize these values.

# BACKEND_PORT is the port where FastAPI backend should run.
BACKEND_PORT=8000

# FRONTEND_PORT is the port where Vite React frontend should run.
FRONTEND_PORT=5173

# DATABASE_URL is the SQLite database location used by SQLAlchemy.
DATABASE_URL=sqlite:///./database/leads.db
